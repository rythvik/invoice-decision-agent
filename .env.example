# ── Extraction ──────────────────────────────────────────────────
# Comma-separated provider chain, tried in order — each provider only fails at
# the point it's actually used, so a missing key/host just falls through silently.
#   ocrspace              → free cloud OCR (https://ocr.space, no card, no signup)
#   ollama                → fully local vision model, no key, no cap (needs Ollama running)
#   gemini                → cloud LLM, needs a free key (below)
#   ocrspace,ollama,gemini → cloud-free first, local fallback, cloud LLM last
EXTRACTION_PROVIDER=ocrspace

# OCR.Space (free tier — https://ocr.space/ocrapi → "Free API Key", no card).
OCRSPACE_API_KEY=paste-your-key-here

# Gemini (free tier — https://aistudio.google.com → "Get API key", no card).
# Multiple models = more free headroom on one key (each has its own daily quota).
GEMINI_API_KEY=paste-your-key-here
GEMINI_MODEL=gemini-flash-latest,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# Ollama (local vision model) — only used if listed in EXTRACTION_PROVIDER.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl

# Content-addressed extraction cache (each unique document read once). off to disable.
EXTRACTION_CACHE=on

# ── Email ingestion (IMAP) ──────────────────────────────────────
# Connect any mailbox to pull invoices. Create an APP PASSWORD on your email
# provider (Gmail/Outlook/Zoho) — never your login password. If unset, the inbox
# is empty and you use the Upload button instead.
INGESTION_SOURCE=imap
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=INBOX

# ── Email ingestion (Gmail "Sign in with Google") ────────────────
# Alternative to the IMAP app-password flow above — OAuth via a Google Cloud
# OAuth client (Desktop app or Web app type). Only needed if you use that flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000
# Alternative to the two vars above: path to a downloaded OAuth client JSON file.
GOOGLE_CREDENTIALS_PATH=
