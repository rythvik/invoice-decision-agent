# ── Extraction provider ─────────────────────────────────────────
# gemini (free tier — https://aistudio.google.com → "Get API key")
EXTRACTION_PROVIDER=gemini
GEMINI_API_KEY=paste-your-key-here
# Comma-separated preference list. Each model has its own free daily quota,
# so listing several gives automatic fallback when one is capped.
GEMINI_MODEL=gemini-flash-latest,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# Content-addressed extraction cache (each unique PDF extracted once). off to disable.
EXTRACTION_CACHE=on

# ── Ingestion (v1 uses the bundled local inbox) ─────────────────
INGESTION_SOURCE=local
